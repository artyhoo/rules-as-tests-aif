{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "coverageAnalysis": "perTest",
  "reporters": ["html", "progress", "clear-text"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "mutate": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.unit.{ts,tsx}",
    "!src/**/*.integration.{ts,tsx}",
    "!src/**/*.audit.{ts,tsx}",
    "!src/**/*.e2e.{ts,tsx}",
    "!src/**/*.stories.{ts,tsx}",
    "!src/**/*.d.ts",
    "!src/**/index.ts",
    "!src/generated/**",
    "!src/app/**/layout.tsx",
    "!src/app/**/page.tsx",
    "!src/app/**/loading.tsx",
    "!src/app/**/error.tsx",
    "!src/app/**/not-found.tsx",
    "!src/web/server.ts",
    "!src/config/env.ts"
  ],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "thresholds": {
    "high": 85,
    "low": 70,
    "break": 60
  },
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "concurrency": 4,
  "timeoutMS": 60000,
  "disableTypeChecks": "{src,tests}/**/*.{ts,tsx}",
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    ".stryker-tmp/**",
    "node_modules/**",
    ".next/**",
    "reports/**"
  ],
  "logLevel": "info"
}
