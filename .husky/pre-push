#!/usr/bin/env bash
# .husky/pre-push — TS-core dispatcher (Wave 10.1).
#
# Capability-check, NOT brand-name detection (dual-implementation-discipline.md
# §4 / §8 #brand-name-detection): route to the TS-core hook when a capable Node
# runtime is present — Node ≥20 (the ESM `--import tsx/esm` loader requires
# ≥20.6; the kickoff's "≥18" predates that constraint). Otherwise degrade to the
# bash fallback (shipped Wave 10.5) or a no-op, so `git push` is never hard-
# blocked merely because Node is absent. All check logic lives in
# packages/core/hooks/pre-push.ts (delegation sections) +
# packages/core/hooks/legacy-trailer-checks.sh (trailer sections, migrating to
# TS in Wave 10.2/10.3).
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
TS_HOOK="$REPO_ROOT/packages/core/hooks/pre-push.ts"
FALLBACK="$REPO_ROOT/packages/core/hooks/pre-push.fallback.sh"

node_major() { node -p 'process.versions.node.split(".")[0]' 2>/dev/null || echo 0; }

if command -v node >/dev/null 2>&1 && [ "$(node_major)" -ge 20 ] && [ -f "$TS_HOOK" ]; then
  exec node --import tsx/esm "$TS_HOOK"
elif [ -x "$FALLBACK" ]; then
  exec bash "$FALLBACK"
else
  echo "⚠ pre-push: Node ≥20 unavailable and no bash fallback present — skipping checks."
  echo "  Install Node ≥20 to enable the TS-core pre-push hook (packages/core/hooks/pre-push.ts)."
  exit 0
fi
