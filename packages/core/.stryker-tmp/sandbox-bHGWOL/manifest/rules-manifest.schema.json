{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "rules-as-tests rules manifest",
  "type": "object",
  "patternProperties": {
    "^(R[0-9]+[a-z]?|IR[0-9]+)$": {
      "type": "object",
      "required": ["title", "stack", "check", "examples"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 5 },
        "stack": {
          "type": "array",
          "items": { "enum": ["ts-server", "react-next", "microservices"] },
          "minItems": 1
        },
        "applies-to": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns, e.g. src/web/handlers/**"
        },
        "requires-package": {
          "type": ["string", "array"],
          "description": "npm package(s) that must be in dependencies for this rule to be applicable. If absent in consumer's package.json and auto-skip-if-missing is true, rule is SKIPPED."
        },
        "auto-skip-if-missing": { "type": "boolean", "default": false },
        "check": {
          "oneOf": [
            { "type": "object", "required": ["type", "rule"], "properties": {
              "type": { "const": "eslint" },
              "rule": { "type": "string" }
            }, "additionalProperties": false },
            { "type": "object", "required": ["type", "command"], "properties": {
              "type": { "const": "command" },
              "command": { "type": "string" }
            }, "additionalProperties": false },
            { "type": "object", "required": ["type", "script"], "properties": {
              "type": { "const": "script" },
              "script": { "type": "string" }
            }, "additionalProperties": false },
            { "type": "object", "required": ["type"], "properties": {
              "type": { "const": "manual" },
              "rationale": { "type": "string" }
            }, "additionalProperties": false }
          ]
        },
        "examples": {
          "type": "object",
          "required": ["bad", "good"],
          "properties": {
            "bad": { "type": "string", "minLength": 1 },
            "good": { "type": "string", "minLength": 1 }
          }
        },
        "policy": {
          "type": "string",
          "description": "Free-form Markdown body for the rule"
        }
      }
    }
  },
  "additionalProperties": false
}
